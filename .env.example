# Copy to .env or export these in your shell. Do not commit .env.

# Slack signal sync. Bot token needs channel history scopes for configured channels.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_IDS=
SLACK_USER_MENTION=

# Linear signal sync. Use API key with read access.
LINEAR_API_KEY=
LINEAR_TEAM_KEY=
LINEAR_LABEL=agent-ready

# GitHub signal sync. Use gh auth or a token with issue read access.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_LABEL=agent-ready

# Oura or other wearable.
# Oura uses Bearer access tokens through its OAuth/API flow.
OURA_ACCESS_TOKEN=

# Agent harness policy.
AGENT_MAX_CONCURRENT=1
AGENT_REQUIRE_CRITIC=1
AGENT_REQUIRE_BROWSER=0
